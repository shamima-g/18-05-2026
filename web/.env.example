# API Configuration
# Copy this file to .env.local and update with your values
NEXT_PUBLIC_API_BASE_URL=http://localhost:8042

# Backend API Authentication
# These are populated by api-connectivity-agent during INTAKE Step 4b when the
# OpenAPI spec declares securitySchemes. Uncomment and set in .env.local only —
# never commit credential values.
#
# NEXT_PUBLIC_API_AUTH_HEADER controls the header name (e.g. Authorization, X-API-Key).
# NEXT_PUBLIC_API_AUTH_VALUE_PREFIX is the literal prefix prepended to the token
#   (include the trailing space if present, e.g. "Bearer ", or leave empty for raw keys).
# NEXT_PUBLIC_API_TOKEN holds the credential value.
#
# Note: NEXT_PUBLIC_* env vars are baked into the browser bundle. For production
# apps that talk to a real backend with sensitive tokens, prefer a BFF pattern
# (token stays server-side) or a Next.js API route proxy. The values below are
# intended for local development against a dev backend — see authentication-intake.md.
#
# NEXT_PUBLIC_API_AUTH_HEADER=Authorization
# NEXT_PUBLIC_API_AUTH_VALUE_PREFIX=Bearer
# NEXT_PUBLIC_API_TOKEN=

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl
